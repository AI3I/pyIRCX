module pyircx-httpd-systemd 1.0;

require {
    type httpd_t;
    type init_t;
    type systemd_unit_file_t;
    class dbus send_msg;
    class system status;
    class service { start stop status reload };
}

#============= httpd_t ==============
allow httpd_t init_t:dbus send_msg;
allow httpd_t init_t:system status;
allow httpd_t init_t:service { start stop status reload };
allow httpd_t systemd_unit_file_t:service { start stop status };
