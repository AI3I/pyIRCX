{
  "server": {
    "name": "trunk.testnet.local",
    "network": "TestNet",
    "motd": [
      "Welcome to TestNet Trunk Server",
      "This is the services trunk"
    ],
    "restrict_to_staff_only": false
  },
  "network": {
    "listen_addr": "127.0.0.1",
    "listen_ports": [6667],
    "enable_ipv6": false
  },
  "database": {
    "path": "trunk_pyircx.db",
    "pool_size": 10
  },
  "limits": {
    "max_users": 10000,
    "max_channels": 2500
  },
  "services": {
    "enabled": true,
    "mode": "centralized",
    "is_services_hub": true,
    "hub_server": null,
    "servicebot_count": 10,
    "servicebot_max_channels": 10
  },
  "linking": {
    "enabled": true,
    "server_role": "trunk",
    "bind_host": "127.0.0.1",
    "bind_port": 7001,
    "links": [
      {
        "name": "branch.testnet.local",
        "host": "127.0.0.1",
        "port": 7002,
        "password": "testlink123",
        "autoconnect": false
      },
      {
        "name": "branch2.testnet.local",
        "host": "127.0.0.1",
        "port": 7003,
        "password": "testlink123",
        "autoconnect": false
      }
    ]
  },
  "admin": {
    "default_username": "admin",
    "default_password": "changeme"
  },
  "security": {
    "enable_flood_protection": false,
    "enable_connection_throttle": false,
    "flood_messages": 9999,
    "flood_window": 1.0,
    "connection_throttle": 99999,
    "throttle_window": 1.0
  },
  "ssl": {
    "enabled": false
  }
}
